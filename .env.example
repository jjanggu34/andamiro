# Supabase - frontend and Vercel API auth check
VITE_SUPABASE_URL=
VITE_SUPABASE_KEY=

# Claude / Anthropic - server only, required by Vite dev proxy and Vercel API
# Do not add a VITE_ prefix to this key.
ANTHROPIC_API_KEY=

# API CORS - optional for deployed /api/chat
ALLOWED_ORIGIN=http://localhost:5173

# Push notifications - optional
VITE_VAPID_PUBLIC_KEY=

# n8n - currently disabled / planned for future use
# Leave this empty unless the n8n workflow should be enabled.
VITE_N8N_WEBHOOK_URL=
